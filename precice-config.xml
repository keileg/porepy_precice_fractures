<?xml version="1.0" encoding="UTF-8" ?>
<precice-configuration>
  <log>
    <sink type="stream" output="stdout" filter="%Severity% > debug"/>
  </log>

  <data:scalar name="pressure-difference"/>
  <data:scalar name="flux"/>

  <mesh name="Macro-Mesh" dimensions="2">
    <use-data name="pressure-difference"/>
    <use-data name="flux"/>
  </mesh>

  <participant name="Macro">
    <provide-mesh name="Macro-Mesh"/>
    <write-data name="pressure-difference" mesh="Macro-Mesh"/>
    <read-data name="flux" mesh="Macro-Mesh"/>
  </participant>

  <participant name="Micro-Manager">
    <receive-mesh name="Macro-Mesh" from="Macro" api-access="true" safety-factor="0"/>
    <read-data name="pressure-difference" mesh="Macro-Mesh"/>
    <write-data name="flux" mesh="Macro-Mesh"/>
  </participant>

  <m2n:sockets acceptor="Micro-Manager"
    connector="Macro"
    exchange-directory=".." />

  <coupling-scheme:serial-implicit>
    <participants first="Macro" second="Micro-Manager"/>
    <time-window-size value="0.1"/>
    <max-time value="0.3"/>
    <max-iterations value="15" />
    <exchange data="pressure-difference" mesh="Macro-Mesh" from="Macro" to="Micro-Manager"/>
    <exchange data="flux" mesh="Macro-Mesh" from="Micro-Manager" to="Macro"/>
    <relative-convergence-measure data="pressure-difference" mesh="Macro-Mesh" limit="1e-7"/>
  </coupling-scheme:serial-implicit>
</precice-configuration>
