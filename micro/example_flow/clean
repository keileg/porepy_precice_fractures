#!/usr/bin/env sh
set -e -u

for d in [0-9]*; do
    [[ -d "$d" ]] || continue

    # Keep the initial condition directory
    [[ "$d" == "0" ]] && continue

    # Remove numeric timestep folders such as 0.1, 10, 250, 1e-05
    if [[ "$d" =~ '^[0-9]+([.][0-9]+)?([eE][-+]?[0-9]+)?$' ]]; then
        rm -rf -- "$d"
    fi
done

rm -rf -- postProcessing

echo "Removed timestep folders and postProcessing/"

