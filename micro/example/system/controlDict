FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     simpleFoam;

startFrom       startTime;

startTime       0;

stopAt          endTime;

endTime         1;

deltaT          0.1;

writeControl    timeStep;

writeInterval   5;

purgeWrite      0;

writeFormat     ascii;

writePrecision  6;

writeCompression off;

timeFormat      general;

timePrecision   6;

runTimeModifiable true;

functions
{
    outletFlux
    {
        type            surfaceFieldValue;
        libs            (fieldFunctionObjects);

        log             true;
        writeControl    timeStep;
        writeInterval   5;

        writeFields     false;
        surfaceFormat   none;

        regionType      patch;
        name            outlet;

        operation       sum;
        fields          (phi);
    }
}

