FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     scalarTransportFoam;

startFrom       startTime;

startTime       0;

stopAt          endTime;

endTime         100;

deltaT          0.05;

writeControl    adjustableRunTime;

writeInterval   10;

purgeWrite      1;

writeFormat     ascii;

writePrecision  6;

writeCompression off;

timeFormat      general;

timePrecision   6;

runTimeModifiable true;

functions
{
    componentsU
    {
        type            components;
        libs            (fieldFunctionObjects);
        field           U;

        executeControl  timeStep;
        executeInterval 1;
        writeControl    none;
    }
    #include "PlaneSamplingT"

    stopAtTracerBreakthrough
    {
        type            runTimeControl;
        libs            (utilityFunctionObjects);

        conditions
        {
            tracerAtOutlet
            {
                type            minMax;
                functionObject  outletFlux;
                fields          ("weightedAreaAverage(outlet,T)");
                value           0.99;
                mode            maximum;
            }
        }
    }
}

